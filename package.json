{
  "name": "@surihoney/priority-queue",
  "version": "0.1.0",
  "description": "Two-tier priority queue with stable FIFO ordering and position-preserving reinsert",
  "author": "Suriyanti Panagen",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/surihoney/priority-queue.git"
  },
  "homepage": "https://github.com/surihoney/priority-queue#readme",
  "bugs": {
    "url": "https://github.com/surihoney/priority-queue/issues"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "priority-queue",
    "fifo",
    "queue",
    "typescript",
    "immutable"
  ],
  "devDependencies": {
    "typescript": "^5.6.3",
    "vitest": "^4.1.0"
  }
}
